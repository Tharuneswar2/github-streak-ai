# ============================================================
# GitHub Streak AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# NVIDIA NIM API Key (required)
# Obtain from: https://build.nvidia.com/
NVIDIA_API_KEY=

# NVIDIA model to use for AI summaries and analysis
MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Base URL for NVIDIA NIM API (default: NVIDIA hosted)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Project root directory (default: current directory)
# PROJECT_ROOT=.

# Timezone for log dates (default: UTC)
# TIMEZONE=UTC

# Maximum tokens for AI responses (default: 2048)
# MAX_TOKENS=2048

# Temperature for AI generation (default: 0.7)
# AI_TEMPERATURE=0.7
