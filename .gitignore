# ============================================================
# GitHub Streak AI — .gitignore
# ============================================================

# Environment & Secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl
pip-wheel-metadata/
.Python

# Virtual Environments
.venv/
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# OS
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# Logs (keep structure, ignore generated content)
# Note: log files ARE tracked — they are the core product.
# Only ignore temporary/debug logs.
*.log
